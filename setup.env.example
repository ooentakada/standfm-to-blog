# ============================================================
# Stand.fm → ブログ自動投稿スキル 設定ファイル
# このファイルを .claude/standfm-to-blog.env にコピーして記入
# ============================================================

# ===========================
# OpenAI APIキー（必須）
# 文字起こし（Whisper）と画像生成（gpt-image-2）に使用
# https://platform.openai.com/api-keys で発行
# ===========================
OPENAI_API_KEY=sk-xxxx...

# ===========================
# 投稿先の選択（必須）
# none     → 投稿しない（下書き生成のみ）
# note     → noteだけに投稿
# wordpress→ WordPressだけに投稿
# both     → 両方に投稿
# ===========================
PUBLISH_TARGET=both

# ===========================
# note設定（PUBLISH_TARGET が note または both の場合に記入）
# ===========================
# あなたのnote URLの末尾の名前
# 例: https://note.com/ooenfes → ooenfes
NOTE_USER_URLNAME=

# セッションファイルの保存先（変更不要）
NOTE_SESSION_FILE=.claude/skills/standfm-to-blog/note_session.json

# ===========================
# WordPress設定（PUBLISH_TARGET が wordpress または both の場合に記入）
# ===========================
# サイトURL（末尾スラッシュなし）
WP_SITE_URL=https://your-site.com

# 管理者ユーザー名
WP_USERNAME=admin

# アプリケーションパスワード
# WordPress管理画面 → ユーザー → プロフィール → アプリケーションパスワード で発行
# スペース区切りのままコピーしてOK（例: abcd efgh ijkl mnop qrst uvwx）
WP_APP_PASSWORD=

# ===========================
# コンテンツ保存先（変更不要でもOK）
# ===========================
CONTENT_DIR=content
